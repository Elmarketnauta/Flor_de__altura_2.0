# Internal API secret - authenticates server-to-server calls (Stripe webhook -> loyalty/award).
# Generate with: openssl rand -hex 32
# MUST be set in production or the loyalty/award endpoint fails closed (403).
INTERNAL_API_SECRET=generate-with-openssl-rand-hex-32

# HubSpot — CRM de leads B2B (Plan Oficina)
# Portal ID: HubSpot → Settings → Account Setup → Account ID
# Form GUID: HubSpot → Marketing → Forms → [tu formulario] → Share → Embed → GUID
